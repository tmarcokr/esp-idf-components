{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Post-Build Sync (Clangd)",
            "type": "shell",
            "command": "ln -sf ${workspaceFolder}/examples/${input:selectedProject}/build ${workspaceFolder}/build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "never",
                "close": true
            }
        },
        {
            "label": "Set ESP-IDF Target",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && idf.py set-target ${input:espTarget}",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/examples/${input:selectedProject}"
            },
            "presentation": {
                "reveal": "always"
            },
            "dependsOn": ["Post-Build Sync (Clangd)"],
            "dependsOrder": "sequence"
        },
        {
            "label": "ESP-IDF Menuconfig",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && idf.py menuconfig",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/examples/${input:selectedProject}"
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "dependsOn": ["Post-Build Sync (Clangd)"],
            "dependsOrder": "sequence"
        },
        {
            "label": "Kill Monitor",
            "type": "shell",
            "command": "pkill -f 'idf.py.*monitor' || pkill -f 'idf_monitor' || fuser -k /dev/ttyACM1 || true",
            "problemMatcher": [],
            "presentation": {
                "reveal": "never",
                "close": true
            }
        },
        {
            "label": "Build ESP-IDF",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && idf.py build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "options": {
                "cwd": "${workspaceFolder}/examples/${input:selectedProject}"
            },
            "presentation": {
                "reveal": "always"
            },
            "dependsOn": ["Post-Build Sync (Clangd)"],
            "dependsOrder": "sequence"
        },
        {
            "label": "Flash ESP-IDF",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && idf.py flash",
            "group": "build",
            "dependsOn": ["Kill Monitor", "Post-Build Sync (Clangd)"],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/examples/${input:selectedProject}"
            }
        },
        {
            "label": "Monitor ESP-IDF",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && idf.py monitor",
            "group": "none",
            "dependsOn": ["Kill Monitor", "Post-Build Sync (Clangd)"],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/examples/${input:selectedProject}"
            }
        },
        {
            "label": "Flash and Monitor ESP-IDF",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && idf.py flash monitor",
            "group": "none",
            "dependsOn": ["Kill Monitor", "Post-Build Sync (Clangd)"],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/examples/${input:selectedProject}"
            }
        },
        {
            "label": "Build Component HIL Test",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && idf.py -C ${env:HOME}/esp/esp-idf/tools/unit-test-app -D EXTRA_COMPONENT_DIRS=\"${workspaceFolder}/components\" -D TEST_COMPONENTS=\"${input:selectedComponent}\" -D IDF_TARGET=${input:espTarget} build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run HIL Hardware Test",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && pytest --embedded-services idf,serial --target ${input:espTarget} --binary-path ${env:HOME}/esp/esp-idf/tools/unit-test-app/build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "dependsOn": ["Kill Monitor"]
        },
        {
            "label": "Manual HIL Test (Flash & Monitor)",
            "type": "shell",
            "command": "source ${env:HOME}/esp/esp-idf/export.sh && idf.py -C ${env:HOME}/esp/esp-idf/tools/unit-test-app -D EXTRA_COMPONENT_DIRS=\"${workspaceFolder}/components\" -D TEST_COMPONENTS=\"${input:selectedComponent}\" -D IDF_TARGET=${input:espTarget} flash monitor",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "dependsOn": ["Kill Monitor"]
        }
    ],
    "inputs": [
        {
            "id": "selectedProject",
            "type": "pickString",
            "description": "Select the example project to work with:",
            "options": [
                "01_gpio_button",
                "02_audio_tone",
                "03_mpu6050_dmp",
                "04_sd_card_basic",
                "05_rgb_led",
                "06_sd_audio_player"
            ],
            "default": "05_rgb_led"
        },
        {
            "id": "selectedComponent",
            "type": "pickString",
            "description": "Select the component to test:",
            "options": [
                "rgb_led",
                "gpio_button",
                "mpu6050",
                "sd_card"
            ],
            "default": "rgb_led"
        },
        {
            "id": "espTarget",
            "type": "pickString",
            "description": "Select the ESP32 target chip for this project:",
            "options": [
                "esp32",
                "esp32s3",
                "esp32c6"
            ],
            "default": "esp32c6"
        }
    ]
}
